{
	"name": "open-meteo-website",
	"type": "module",
	"author": "Open-Meteo <info@open-meteo.com>",
	"private": true,
	"version": "1.60.5",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/open-meteo/open-meteo-website.git"
	},
	"description": "This package contains the Open-Meteo website",
	"scripts": {
		"dev": "svelte-kit sync && vite dev --host",
		"build": "svelte-kit sync && vite build -l info",
		"build-weather": "BUILD_WEATHER_PAGES=true svelte-kit sync && BUILD_WEATHER_PAGES=true vite build -l info",
		"staging": "NODE_ENV=development vite build --mode development",
		"preview": "vite preview --host",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"test": "vitest",
		"coverage": "vitest run --coverage",
		"format": "prettier --write .",
		"rename_index_files": "node scripts/rename_to_index_html.js",
		"update-components": "npx shadcn-svelte@latest add -y -o accordion alert button calendar checkbox dialog dropdown-menu input label popover range-calendar select separator sonner toggle toggle-group",
		"build:preview": "npm run build && npm run preview"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.23.0",
		"@poppanator/sveltekit-svg": "^7.0.0",
		"@shikijs/transformers": "^4.3.0",
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/container-queries": "^0.1.1",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.16",
		"@tailwindcss/vite": "^4.3.0",
		"@trivago/prettier-plugin-sort-imports": "^6.0.0",
		"@types/node": "^26.1.0",
		"@vitest/coverage-v8": "^4.1.0",
		"autoprefixer": "^10.5.0",
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"cookie": "^2.0.1",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.1",
		"eslint-plugin-svelte": "^3.20.0",
		"formsnap": "^2.0.0",
		"globals": "^17.7.0",
		"highcharts": "13.0.0",
		"jsdom": "^29.1.0",
		"lucide-static": "^1.23.0",
		"mdsvex": "^0.12.3",
		"mode-watcher": "^1.1.0",
		"openmeteo": "^1.2.0",
		"prettier": "^3.9.3",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"prism-themes": "^1.9.0",
		"rollup-plugin-visualizer": "^7.0.0",
		"shiki": "^4.3.0",
		"simple-icons": "^16.25.0",
		"svelte": "^5.56.0",
		"svelte-check": "^4.7.1",
		"svelte-persisted-store": "^0.12.0",
		"sveltekit-superforms": "^2.30.0",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.0.3",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.1.0",
		"vitest": "^4.0.4",
		"zod": "^4.4.3"
	}
}
